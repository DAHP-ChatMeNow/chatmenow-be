# Backend
PORT=5000
MONGO_URI=mongodb://localhost:27017/chatmenow
JWT_SECRET=replace_with_strong_secret
API_KEY=replace_with_api_key
ALLOWED_ORIGINS=http://localhost:3000

# AWS S3
AWS_ACCESS_KEY_ID=replace_with_key
AWS_SECRET_ACCESS_KEY=replace_with_secret
S3_BUCKET_NAME=replace_with_bucket
AWS_REGION=ap-southeast-1

# LiveKit (backend runtime)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# Frontend (Next.js)
NEXT_PUBLIC_ENABLE_CALL=false
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
